{
  "name": "danmaku-electron",
  "version": "1.2.2",
  "build": {
    "appId": "com.example.danmaku",
    "mac": {
      "identity": null,
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "directories": {
      "output": "dist"
    }
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dist": "electron-builder",
    "release": "release-it"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Danmaku Electron アプリ（タスクトレイ駐在・前面表示・透過ウィンドウ・テキスト横流し）",
  "devDependencies": {
    "electron": "^38.1.2",
    "electron-builder": "^26.8.1",
    "release-it": "^17.10.1",
    "@release-it/conventional-changelog": "^8.0.2",
    "conventional-commits-filter": "^5.0.0",
    "conventional-commits-parser": "^6.4.0"
  },
  "files": [
    "main.js",
    "index.html",
    "tray.png",
    "assets/icon.png"
  ],
  "dependencies": {
    "@huggingface/transformers": "^4.1.0"
  }
}
